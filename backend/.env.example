PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/portfolio_saas
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
FRONTEND_URL=http://localhost:3000
# Set this to YOUR username so / shows your portfolio
OWNER_USERNAME=gauravsahu

# Stripe billing (Pro plan / premium themes)
# Leave these blank to develop without billing — checkout endpoints will
# return a clear 503 "not configured" error instead of crashing.
# In development, use the /api/billing/dev-upgrade route instead (auto-disabled in production).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Razorpay (Pro plan checkout — India). Replaces the old manually-entered
# UPI ID flow: this creates a real order server-side with a fixed amount
# and verifies the payment signature before granting Pro access, instead of
# trusting a self-reported UTR number.
# Get these from Razorpay Dashboard → Settings → API Keys.
# Leave blank to develop without payments — /api/payments/create-order will
# return a clear 503 "not configured" error instead of crashing.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Razorpay Dashboard → Settings → Webhooks. Point the webhook URL at
# https://YOUR_DOMAIN/api/payments/webhook and subscribe to at least
# payment.captured and payment.failed.
RAZORPAY_WEBHOOK_SECRET=
# Pro plan price in PAISE (smallest INR unit) — 69900 = ₹699.00. Optional;
# defaults to 69900 if unset. This is the ONE base price both payment
# methods use (see backend/config/pricing.js): Razorpay charges exactly
# this, and Manual UPI's admin-configured discount (Settings → Manual UPI
# Payment Settings) is calculated as a percentage or flat amount off this
# same number — so the two methods can never end up quoting two different
# "full" prices for Pro.
RAZORPAY_PRO_PLAN_AMOUNT_PAISE=69900

# Email (Forgot/Reset Password) — Nodemailer SMTP
# Leave these blank to develop without email — forgotPassword will log the
# reset link to the SERVER console instead of actually emailing it
# (see backend/utils/sendEmail.js). Works with Gmail SMTP, SendGrid,
# Mailgun, AWS SES, or any standard SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PortfolioForge <no-reply@portfolioforge.dev>"
